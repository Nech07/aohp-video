{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      "@launchpad/shared": ["../../packages/shared/src"],
      "@launchpad/shared/*": ["../../packages/shared/src/*"],
      "@launchpad/assets": ["../../packages/assets"],
      "@launchpad/assets/*": ["../../packages/assets/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
